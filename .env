# ========================
# PostgreSQL Configuration
# ========================
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=admin

# ========================
# Airflow Admin User
# ========================
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_FIRSTNAME=Admin
AIRFLOW_LASTNAME=User
AIRFLOW_ROLE=Admin
AIRFLOW_EMAIL=admin@example.com

# ========================
# Airflow Secret Key (must be the same across all Airflow components)
# ========================
AIRFLOW_SECRET_KEY=my_super_secret_key_change_me_in_production

CASSANDRA_USERNAME=admin
CASSANDRA_PASSWORD=admin
CASSANDRA_HOST=localhost